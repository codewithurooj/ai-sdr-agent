# ── LLM ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Prospect Research ───────────────────────────────────────────────────────
APOLLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email Sending (Gmail SMTP) ───────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Database ────────────────────────────────────────────────────────────────
# SQLite (dev) — leave as-is for local development
DATABASE_URL=sqlite+aiosqlite:///./sdr_agent.db

# PostgreSQL (prod) — uncomment and fill in for production (requires asyncpg)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sdr_agent

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set in frontend/.env.local (dev) or Vercel dashboard (prod)
NEXT_PUBLIC_API_URL=http://localhost:8000
